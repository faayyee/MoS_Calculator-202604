<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.result.ResultFragment">




    <!-- 固定在顶部的戻る按钮 -->

    <!-- 滚动区域 -->

    <TextView
        android:id="@+id/text_back"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:clickable="true"
        android:drawablePadding="8dp"
        android:focusable="true"
        android:padding="8dp"
        android:text="戻る"
        android:textColor="#FF5722"
        android:textSize="20sp"
        android:tint="#FF5722"
        app:drawableStartCompat="@drawable/ic_arrow_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_back">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 分析完成 -->
            <TextView
                android:id="@+id/text_result_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingBottom="16dp"
                android:text="分析が完了しました"
                android:textColor="#000000"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- MoS 最大最小 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingBottom="4dp"
                android:text="MoSの最大値：0.034m"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingBottom="8dp"
                android:text="MoSの最小値：0.011m"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- 参考基準 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingBottom="12dp"
                android:text="(参考基準値：??―??)"
                android:textColor="#888888" />

            <!-- 分割线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="12dp"
                android:background="#CCCCCC" />

            <!-- 显示图表按钮 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/button_show_graph"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:clickable="true"
                    android:elevation="2dp"
                    android:focusable="true"
                    android:fontFamily="sans-serif-medium"
                    android:paddingBottom="8dp"
                    android:shadowColor="#888888"
                    android:shadowDx="3"
                    android:shadowDy="2"
                    android:shadowRadius="4"
                    android:text="グラフで結果を見る"
                    android:textColor="#2196F3"
                    android:textSize="22sp" />

                <ImageButton
                    android:id="@+id/button_download_csv"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="10dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="CSVを保存"
                    android:src="@drawable/ic_download"/>
            </LinearLayout>


            <!-- 图表区域（默认隐藏） -->
            <LinearLayout
                android:id="@+id/layout_graph_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- 加速度图 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:paddingBottom="4dp"
                    android:text="加速度(m/s²)"
                    android:textSize="16sp" />

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/chart_acc"
                    android:layout_width="match_parent"
                    android:layout_height="300dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="16dp" />

                <!-- 角速度图 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:paddingBottom="4dp"
                    android:text="角速度(rad/s)"
                    android:textSize="16sp" />

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/chart_gyr"
                    android:layout_width="match_parent"
                    android:layout_height="300dp" />
            </LinearLayout>


        </LinearLayout>
    </ScrollView>

    <!-- 遮罩层：默认隐藏 -->
    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="0dp"
        android:background="#80000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
